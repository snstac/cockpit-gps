#!/usr/bin/env python3
# SPDX-License-Identifier: Apache-2.0
#
# gps-integrity — spoof/jam monitor for gpsd feeds.
#
# Works with any gpsd-backed receiver. Legacy NMEA receivers get heuristic
# checks (position vs reference, time vs NTP, C/N₀ profile, constellation
# health). u-blox receivers with bidirectional UBX additionally surface
# native MON-RF jamming telemetry via read-only ubxtool polls through gpsd.
#
# Output: /run/gps-integrity/status.json (rewritten ~1/s) and journal logs.

import json
import math
import os
import re
import socket
import statistics
import subprocess
import sys
import time
from collections import deque
from datetime import datetime, timezone

CONF_PATH = "/etc/gps-integrity.conf"
STATE_DIR = os.environ.get("STATE_DIRECTORY", "/var/lib/gps-integrity")
RUNTIME_DIR = os.environ.get("RUNTIME_DIRECTORY", "/run/gps-integrity")
REF_PATH = os.path.join(STATE_DIR, "reference.json")
STATUS_PATH = os.path.join(RUNTIME_DIR, "status.json")

DEFAULTS = {
    "gpsd_host": "127.0.0.1",
    "gpsd_port": 2947,
    "stationary": True,
    "survey_samples": 90,
    "persist_s": 5,
    "pos_warn_m": 15.0,
    "pos_crit_m": 50.0,
    "time_warn_s": 1.0,
    "time_crit_s": 3.0,
    "vel_warn_ms": 1.5,
    "vel_crit_ms": 5.0,
    "cn0_uniform_spread": 8.0,
    "cn0_uniform_mean": 45.0,
    "cn0_uniform_minsats": 6,
    "cn0_drop_db": 10.0,
    "min_sats": 4,
    "ref_lat": None,
    "ref_lon": None,
    "ref_alt": None,
    # u-blox UBX (optional; auto-enabled when gpsd reports u-blox + native)
    "ubx_poll_enable": True,
    "ubx_poll_interval_s": 5.0,
    "ubx_jam_warn_ind": 15,          # MON-RF jamInd threshold (0-255)
    "ubx_jam_crit_ind": 30,
}

GNSS = {0: "GPS", 1: "SBAS", 2: "GAL", 3: "BDS", 4: "IMES", 5: "QZSS", 6: "GLO", 7: "NavIC"}
JAM_STATE_RANK = {"OK": 0, "Warning": 1, "Critical": 2, "Unknown": 0}
RF_BAND = {0: "L1", 1: "L2/L5", 2: "L6", 3: "L1"}


def load_conf():
    conf = dict(DEFAULTS)
    try:
        with open(CONF_PATH) as f:
            conf.update(json.load(f))
    except FileNotFoundError:
        pass
    except Exception as e:
        log(f"WARN config {CONF_PATH} ignored: {e}")
    return conf


def log(msg):
    print(f"{datetime.now(timezone.utc).isoformat(timespec='seconds')} {msg}", flush=True)


def haversine_m(lat1, lon1, lat2, lon2):
    r = 6371000.0
    p1, p2 = math.radians(lat1), math.radians(lat2)
    dp = math.radians(lat2 - lat1)
    dl = math.radians(lon2 - lon1)
    a = math.sin(dp / 2) ** 2 + math.cos(p1) * math.cos(p2) * math.sin(dl / 2) ** 2
    return 2 * r * math.asin(min(1.0, math.sqrt(a)))


class GpsdStream:
    """Line-reader for the gpsd JSON protocol with auto-reconnect."""

    def __init__(self, host, port):
        self.host, self.port = host, port
        self.sock = None
        self.buf = b""

    def _connect(self):
        self.sock = socket.create_connection((self.host, self.port), timeout=10)
        self.sock.sendall(b'?WATCH={"enable":true,"json":true}\n')
        self.buf = b""

    def messages(self):
        while True:
            if self.sock is None:
                try:
                    self._connect()
                except OSError as e:
                    log(f"WARN gpsd connect failed: {e}; retrying")
                    time.sleep(3)
                    continue
            try:
                chunk = self.sock.recv(8192)
                if not chunk:
                    raise OSError("gpsd closed connection")
                self.buf += chunk
            except OSError as e:
                log(f"WARN gpsd read error: {e}; reconnecting")
                try:
                    self.sock.close()
                except OSError:
                    pass
                self.sock = None
                continue
            while b"\n" in self.buf:
                line, self.buf = self.buf.split(b"\n", 1)
                line = line.strip()
                if not line:
                    continue
                try:
                    yield json.loads(line)
                except ValueError:
                    continue


class UbxPoller:
    """Read-only MON-RF / receiver identity via ubxtool through gpsd."""

    _RE_NOISE = re.compile(r"noisePerMS\s+(\d+)\s+agcCnt\s+(\d+)\s+jamInd\s+(\d+)")
    _RE_JAMSTATE = re.compile(r"jammingState\s+\((\w+)\)\s+antStatus\s+\((\w+)\)")
    _RE_MODEL = re.compile(r"MOD=(\S+)")
    _RE_FW = re.compile(r"FWVER=(\S+)")

    def __init__(self, conf):
        self.conf = conf
        self.device_path = None
        self.model = None
        self.firmware = None
        self.last_rf = None
        self.last_poll = 0.0
        self._identified = False
        self._native = False

    def update_device(self, dev):
        if not dev:
            return
        if dev.get("path"):
            self.device_path = dev.get("path")
        driver = dev.get("driver", "")
        if "native" in dev:
            self._native = bool(dev.get("native"))
        if driver == "u-blox" and self._native and self.conf.get("ubx_poll_enable", True):
            if not self._identified:
                self._identify()

    @property
    def ubx_active(self):
        return bool(self.device_path and self.last_rf)

    @staticmethod
    def _parse_mon_rf(text):
        """Line-oriented MON-RF parser (ubxtool -v 2 decodes jammingState)."""
        blocks = []
        cur_id = None
        pending = None
        in_mon_rf = False
        for line in text.splitlines():
            line = line.strip()
            if line.startswith("UBX-MON-RF"):
                if blocks:
                    break
                in_mon_rf = True
                continue
            if not in_mon_rf:
                continue
            if line.startswith("UBX-") and blocks:
                break
            if line.startswith("blockId "):
                parts = line.split()
                if len(parts) >= 2:
                    cur_id = int(parts[1])
            m = UbxPoller._RE_NOISE.search(line)
            if m and cur_id is not None:
                pending = {
                    "block_id": cur_id,
                    "band": RF_BAND.get(cur_id, f"RF{cur_id}"),
                    "noise_per_ms": int(m.group(1)),
                    "agc_cnt": int(m.group(2)),
                    "jam_ind": int(m.group(3)),
                    "jamming_state": "Unknown",
                    "ant_status": "Unknown",
                }
            m = UbxPoller._RE_JAMSTATE.search(line)
            if m and pending is not None:
                pending["jamming_state"] = m.group(1)
                pending["ant_status"] = m.group(2)
                blocks.append(pending)
                pending = None
        return blocks

    def _identify(self):
        if not self.device_path:
            return
        try:
            out = subprocess.run(
                ["ubxtool", "--device", self.device_path, "-p", "MON-VER", "-r", "-w", "2", "-v", "2"],
                capture_output=True, text=True, timeout=8, check=False,
            )
            text = out.stdout + out.stderr
            for line in text.splitlines():
                if "MOD=" in line:
                    self.model = line.split("MOD=", 1)[1].strip().split()[0]
                if "FWVER=" in line:
                    self.firmware = line.split("FWVER=", 1)[1].strip().split()[0]
            if not self.model:
                m = self._RE_MODEL.search(text)
                if m:
                    self.model = m.group(1)
            if not self.firmware:
                f = self._RE_FW.search(text)
                if f:
                    self.firmware = f.group(1)
            self._identified = True
            if self.model:
                log(f"INFO u-blox receiver: {self.model} ({self.firmware or 'unknown FW'})")
        except (OSError, subprocess.TimeoutExpired) as e:
            log(f"WARN u-blox identify failed: {e}")

    def poll_if_due(self, dev):
        self.update_device(dev)
        if not self.device_path or not dev or dev.get("driver") != "u-blox":
            return
        if not self.conf.get("ubx_poll_enable", True):
            return
        now = time.monotonic()
        if now - self.last_poll < self.conf.get("ubx_poll_interval_s", 5.0):
            return
        self.last_poll = now
        try:
            out = subprocess.run(
                ["ubxtool", "--device", self.device_path, "-p", "MON-RF", "-r", "-w", "2", "-v", "2"],
                capture_output=True, text=True, timeout=8, check=False,
            )
            blocks = self._parse_mon_rf(out.stdout + out.stderr)
            if blocks:
                self.last_rf = {"blocks": blocks, "ts": datetime.now(timezone.utc).isoformat(timespec="seconds")}
        except (OSError, subprocess.TimeoutExpired) as e:
            log(f"WARN MON-RF poll failed: {e}")

    def receiver_doc(self, dev):
        if not dev:
            return {"tier": "unknown", "driver": None}
        driver = dev.get("driver", "unknown")
        native = self._native
        if driver == "u-blox" and (native or self.last_rf):
            tier = "ubx"
        elif driver == "u-blox":
            tier = "enhanced"
        elif driver == "NMEA0183":
            tier = "legacy"
        else:
            tier = "legacy"
        caps = ["heuristic"]
        if driver == "u-blox":
            caps.append("ubx")
        if native:
            caps.extend(["nav-pvt", "mon-rf"])
        if self.last_rf:
            caps.append("rf-live")
        return {
            "tier": tier,
            "driver": driver,
            "native": native,
            "path": dev.get("path"),
            "bps": dev.get("bps"),
            "model": self.model,
            "firmware": self.firmware,
            "capabilities": caps,
        }


class Monitor:
    def __init__(self, conf):
        self.conf = conf
        self.ref = None
        self.ref_mode = "surveying"
        self.survey = []
        self.cn0_hist = deque(maxlen=600)
        self.const_baseline = set()
        self.bad_since = {}
        self.overall = "init"
        self.start = time.monotonic()
        self.last_time_delta = None
        self.device = {}
        self.ubx = UbxPoller(conf)
        self.load_reference()

    def load_reference(self):
        c = self.conf
        if c["ref_lat"] is not None and c["ref_lon"] is not None:
            self.ref = {"lat": c["ref_lat"], "lon": c["ref_lon"], "alt": c.get("ref_alt")}
            self.ref_mode = "configured"
            log(f"INFO using configured reference {self.ref}")
            return
        try:
            with open(REF_PATH) as f:
                self.ref = json.load(f)
            self.ref_mode = "surveyed"
            log(f"INFO loaded surveyed reference {self.ref}")
        except FileNotFoundError:
            log("INFO no reference yet — surveying in")

    def save_reference(self):
        os.makedirs(STATE_DIR, exist_ok=True)
        tmp = REF_PATH + ".tmp"
        with open(tmp, "w") as f:
            json.dump(self.ref, f)
        os.replace(tmp, REF_PATH)

    def survey_in(self, tpv):
        if tpv.get("mode") != 3 or tpv.get("lat") is None:
            return
        self.survey.append((tpv["lat"], tpv["lon"], tpv.get("altMSL")))
        if len(self.survey) >= self.conf["survey_samples"]:
            lats = [s[0] for s in self.survey]
            lons = [s[1] for s in self.survey]
            alts = [s[2] for s in self.survey if s[2] is not None]
            self.ref = {
                "lat": statistics.fmean(lats),
                "lon": statistics.fmean(lons),
                "alt": statistics.fmean(alts) if alts else None,
            }
            self.ref_mode = "surveyed"
            self.save_reference()
            log(f"INFO survey-in complete over {len(self.survey)} fixes: {self.ref}")

    def check_position(self, tpv):
        if self.ref is None:
            return ("ok", f"surveying ({len(self.survey)}/{self.conf['survey_samples']})", {"surveying": True})
        if tpv.get("lat") is None:
            return ("ok", "no fix", {})
        d = haversine_m(self.ref["lat"], self.ref["lon"], tpv["lat"], tpv["lon"])
        sev = "crit" if d > self.conf["pos_crit_m"] else "warn" if d > self.conf["pos_warn_m"] else "ok"
        return (sev, f"{d:.2f} m off reference", {"offset_m": round(d, 2)})

    @staticmethod
    def parse_gps_epoch(t):
        try:
            return datetime.fromisoformat(t.replace("Z", "+00:00")).timestamp()
        except (ValueError, AttributeError):
            return None

    def check_time(self, tpv):
        delta = self.last_time_delta
        if delta is None:
            return ("ok", "no time", {})
        ad = abs(delta)
        sev = "crit" if ad > self.conf["time_crit_s"] else "warn" if ad > self.conf["time_warn_s"] else "ok"
        return (sev, f"{delta * 1000:+.0f} ms vs system/NTP", {"delta_ms": round(delta * 1000)})

    def check_velocity(self, tpv):
        if not self.conf["stationary"] or tpv.get("speed") is None:
            return ("ok", "n/a", {})
        v = tpv["speed"]
        sev = "crit" if v > self.conf["vel_crit_ms"] else "warn" if v > self.conf["vel_warn_ms"] else "ok"
        return (sev, f"{v:.2f} m/s", {"speed_ms": round(v, 2)})

    def check_cn0(self, sky):
        sats = [s for s in (sky.get("satellites") or []) if (s.get("ss") or 0) > 0]
        if len(sats) < self.conf["cn0_uniform_minsats"]:
            return ("ok", f"{len(sats)} signals", {"nsig": len(sats)})
        ss = [s["ss"] for s in sats]
        spread = max(ss) - min(ss)
        mean = statistics.fmean(ss)
        uniform = spread < self.conf["cn0_uniform_spread"] and mean > self.conf["cn0_uniform_mean"]
        sev = "warn" if uniform else "ok"
        detail = f"spread {spread:.0f} dB-Hz, mean {mean:.0f}"
        if uniform:
            detail += " (uniform/high — possible spoof)"
        return (sev, detail, {"spread": round(spread, 1), "mean": round(mean, 1), "nsig": len(sats)})

    def check_jamming(self, tpv, sky):
        # Heuristic C/N₀ collapse — always available; supplementary when MON-RF live.
        sats = [s for s in (sky.get("satellites") or []) if (s.get("ss") or 0) > 0]
        mode = tpv.get("mode", 0)
        prefix = "heuristic: " if self.ubx.last_rf else ""
        if not sats:
            if self.cn0_hist:
                return ("crit", f"{prefix}no satellite signals", {"sats": 0, "median": None, "mode": mode})
            return ("ok", f"{prefix}acquiring", {"sats": 0})
        med = statistics.median([s["ss"] for s in sats])
        self.cn0_hist.append(med)
        baseline = statistics.median(self.cn0_hist) if len(self.cn0_hist) >= 30 else med
        drop = baseline - med
        lost = mode < 2 and len(self.cn0_hist) >= 30
        few = len(sats) < self.conf["min_sats"]
        if lost or (drop >= self.conf["cn0_drop_db"] and few):
            sev = "crit" if lost else "warn"
        elif drop >= self.conf["cn0_drop_db"] or few:
            sev = "warn"
        else:
            sev = "ok"
        detail = f"{prefix}{len(sats)} sats, median {med:.0f} dB-Hz (base {baseline:.0f})"
        return (sev, detail, {"sats": len(sats), "median": round(med, 1),
                              "baseline": round(baseline, 1), "mode": mode})

    def check_rf_jamming(self):
        rf = self.ubx.last_rf
        if not rf or not rf.get("blocks"):
            return ("ok", "n/a (no UBX MON-RF)", {"source": "none"})
        blocks = rf["blocks"]
        worst_state = "OK"
        worst_ind = 0
        worst_band = None
        for b in blocks:
            st = b.get("jamming_state", "Unknown")
            if JAM_STATE_RANK.get(st, 0) > JAM_STATE_RANK.get(worst_state, 0):
                worst_state = st
                worst_band = b.get("band")
            ind = b.get("jam_ind", 0)
            if ind > worst_ind:
                worst_ind = ind
        sev = "ok"
        if worst_state == "Critical" or worst_ind >= self.conf["ubx_jam_crit_ind"]:
            sev = "crit"
        elif worst_state == "Warning" or worst_ind >= self.conf["ubx_jam_warn_ind"]:
            sev = "warn"
        parts = [f"{b['band']}: {b['jamming_state']} (jamInd {b['jam_ind']})" for b in blocks]
        detail = "; ".join(parts)
        return (sev, detail, {
            "source": "mon-rf",
            "worst_state": worst_state,
            "worst_band": worst_band,
            "worst_jam_ind": worst_ind,
            "blocks": len(blocks),
        })

    def check_constellations(self, sky):
        systems = sorted({GNSS.get(s.get("gnssid"), "?")
                          for s in (sky.get("satellites") or []) if (s.get("ss") or 0) > 0})
        systems = [s for s in systems if s not in ("?", "SBAS")]
        self.const_baseline |= set(systems)
        n_base = len(self.const_baseline)
        sev = "ok"
        if n_base >= 3 and len(systems) <= 1:
            sev = "warn"
        detail = " ".join(systems) if systems else "none"
        return (sev, detail, {"systems": systems})

    SEV_RANK = {"ok": 0, "warn": 1, "crit": 2}

    def apply_persistence(self, name, sev):
        now = time.monotonic()
        if sev == "ok":
            self.bad_since.pop(name, None)
            return "ok"
        since = self.bad_since.setdefault(name, now)
        if now - since >= self.conf["persist_s"]:
            return sev
        return "ok"

    def evaluate(self, tpv, sky):
        raw = {
            "position": self.check_position(tpv),
            "time": self.check_time(tpv),
            "velocity": self.check_velocity(tpv),
            "cn0": self.check_cn0(sky),
            "jamming": self.check_jamming(tpv, sky),
            "constellations": self.check_constellations(sky),
        }
        if self.ubx.last_rf:
            raw["rf_jamming"] = self.check_rf_jamming()
        checks = {}
        worst = "ok"
        for name, (sev, detail, extra) in raw.items():
            eff = self.apply_persistence(name, sev)
            checks[name] = {"status": eff, "detail": detail, **extra}
            if self.SEV_RANK[eff] > self.SEV_RANK[worst]:
                worst = eff
        if self.ref is None:
            worst = "init"
        return checks, worst

    def write_status(self, checks, overall, tpv):
        os.makedirs(RUNTIME_DIR, exist_ok=True)
        doc = {
            "ts": datetime.now(timezone.utc).isoformat(timespec="milliseconds"),
            "overall": overall,
            "reference_mode": self.ref_mode,
            "reference": self.ref,
            "fix_mode": tpv.get("mode", 0),
            "uptime_s": int(time.monotonic() - self.start),
            "receiver": self.ubx.receiver_doc(self.device),
            "checks": checks,
        }
        if self.ubx.last_rf:
            doc["rf"] = self.ubx.last_rf
        if tpv.get("eph") is not None:
            doc["precision"] = {
                "eph_m": round(tpv["eph"], 3),
                "sep_m": round(tpv["sep"], 3) if tpv.get("sep") is not None else None,
                "epv_m": round(tpv["epv"], 3) if tpv.get("epv") is not None else None,
            }
        tmp = STATUS_PATH + ".tmp"
        fd = os.open(tmp, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o644)
        with os.fdopen(fd, "w") as f:
            json.dump(doc, f)
        os.replace(tmp, STATUS_PATH)
        if overall != self.overall:
            log(f"{overall.upper()} overall integrity -> {overall} "
                + "; ".join(f"{k}={v['status']}:{v['detail']}"
                            for k, v in checks.items() if v["status"] != "ok"))
            self.overall = overall

    def run(self):
        stream = GpsdStream(self.conf["gpsd_host"], self.conf["gpsd_port"])
        tpv = {}
        sky_acc = {}
        sky_last = {}
        last_tick = 0.0
        for msg in stream.messages():
            cls = msg.get("class")
            if cls == "TPV":
                tpv = msg
                if msg.get("eph") is not None:
                    self.ubx._native = True
                epoch = self.parse_gps_epoch(msg.get("time"))
                if epoch is not None:
                    self.last_time_delta = time.time() - epoch
                if self.ref is None:
                    self.survey_in(msg)
            elif cls == "SKY" and msg.get("satellites"):
                if len(msg["satellites"]) >= len(sky_acc.get("satellites") or []):
                    sky_acc = msg
            elif cls == "DEVICE":
                self.device = {**self.device, **msg}
            elif cls == "DEVICES":
                devices = msg.get("devices") or []
                if devices:
                    self.device = {**self.device, **devices[0]}
            self.ubx.poll_if_due(self.device)
            now = time.monotonic()
            if now - last_tick >= 1.0:
                last_tick = now
                sky = sky_acc if sky_acc.get("satellites") else sky_last
                checks, overall = self.evaluate(tpv, sky)
                self.write_status(checks, overall, tpv)
                sky_last = sky
                sky_acc = {}


def main():
    conf = load_conf()
    log(f"INFO gps-integrity starting (stationary={conf['stationary']}, ubx_poll={conf.get('ubx_poll_enable', True)})")
    Monitor(conf).run()


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        pass
    except Exception as e:
        log(f"FATAL {e}")
        sys.exit(1)
